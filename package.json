{
  "name": "n8n-nodes-uqr-ai",
  "version": "1.0.3",
  "description": "n8n community node for uqr.ai - Dynamic QR Code API",
  "keywords": [
    "n8n-community-node",
    "uqr",
    "qr-code",
    "automation",
    "dynamic-qr"
  ],
  "license": "MIT",
  "homepage": "https://uqr.ai",
  "author": {
    "name": "uqr.ai",
    "email": "support@uqr.ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danyeldev/n8n-nodes-uqr-ai.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons && gulp build:json",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "echo 'Skipping lint'",
    "lintfix": "echo 'Skipping lintfix'",
    "prepublishOnly": "npm run build && npm run lint -s"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/UqrAiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/UqrAi/UqrAi.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "gulp-rename": "^2.1.0",
    "n8n-workflow": "^1.18.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
